# --- Database ---
# Inside Docker the host is "db" (compose service name).
# Locally without Docker, use "localhost".
DATABASE_URL=postgresql+asyncpg://pos:pos@db:5432/pos
# Postgres container credentials (must match user/pass/db in DATABASE_URL)
POSTGRES_USER=pos
POSTGRES_PASSWORD=pos
POSTGRES_DB=pos

# --- Admin panel ---
# JWT signing secret for admin sessions. If unset, a random one is
# generated per process — sessions invalidate on every restart.
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Default admin credentials, used ONLY on first startup if no admin
# exists yet. Change them via the admin panel after first login.
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=admin123
